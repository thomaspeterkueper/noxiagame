-- ── 2) Tagesaufgaben-Tabelle ──────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS daily_tasks (
  id            uuid        PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id    uuid        NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  task_date     date        NOT NULL DEFAULT CURRENT_DATE,
  completed     boolean     NOT NULL DEFAULT false,
  points_earned integer,
  created_at    timestamptz NOT NULL DEFAULT now(),
  UNIQUE (profile_id, task_date)
);

CREATE INDEX IF NOT EXISTS idx_daily_tasks_profile
  ON daily_tasks (profile_id, task_date DESC);

ALTER TABLE daily_tasks ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Eigene Tagesaufgaben lesen"
  ON daily_tasks FOR SELECT
  USING (profile_id = auth.uid());

CREATE POLICY "Service kann schreiben"
  ON daily_tasks FOR ALL
  USING (true) WITH CHECK (true);

-- ── 3) Hilfsfunktion: aktuellen Level ermitteln ───────────────────────────────
CREATE OR REPLACE FUNCTION get_knowledge_level(p_points integer)
RETURNS knowledge_levels LANGUAGE sql STABLE AS $$
  SELECT * FROM knowledge_levels
  WHERE min_points <= p_points
    AND (max_points IS NULL OR max_points >= p_points)
  LIMIT 1;
$$;

-- ── Kontrolle ─────────────────────────────────────────────────────────────────
SELECT level, title, min_points, max_points, color FROM knowledge_levels ORDER BY level;
