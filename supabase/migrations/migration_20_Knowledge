-- Migration 020: Wissens-Stufen + Tagesaufgabe
-- Stand: 21.06.2026 · Alpha 0.1.5
--
-- STUFEN (knowledge_points → Titel):
--   0–99:    Lehrling
--   100–499: Händler
--   500–1999: Navigator
--   2000–4999: Ingenieur
--   5000–9999: Wissenschaftler
--   10000+:  Pionier
--
-- TAGESAUFGABE:
--   Eine besondere Aufgabe pro Spieler pro Tag, 2× Punkte.
--   daily_tasks: id, profile_id, date, completed, points_earned

-- ── 1) Stufen-Tabelle (Referenz) ──────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS knowledge_levels (
  level       integer PRIMARY KEY,
  title       text    NOT NULL,
  min_points  integer NOT NULL,
  max_points  integer,           -- null = unbegrenzt (höchste Stufe)
  color       text    NOT NULL,  -- CSS-Farbe für UI
  description text
);

