# NOXIA environment variables
# Copy this file to .env.local for local development.
# Never commit real secrets.

# Supabase — public client configuration
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key

# Secrets — server only
# Configure these as Sensitive values in Vercel.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
CRON_SECRET=replace-with-random-cron-secret

# Knowledge / SSF integration
# SSF_BASE_URL is canonical. SSF_API_BASE_URL is deprecated and only retained
# in code as a temporary backwards-compatible alias.
SSF_BASE_URL=https://solarsciencefoundation.vercel.app
KNOWLEDGE_SOURCE=local

# Optional deprecated alias — do not use for new deployments
# SSF_API_BASE_URL=https://solarsciencefoundation.vercel.app
